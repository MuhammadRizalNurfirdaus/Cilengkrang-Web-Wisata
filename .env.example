# ============================
# DATABASE
# ============================
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=cilengkrang_web_wisata_ts
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# ============================
# BACKEND
# ============================
DATABASE_URL=mysql://your_db_user:your_db_password@db:3306/cilengkrang_web_wisata_ts
JWT_SECRET=your_jwt_secret_here_change_this
PORT=3001

# ============================
# GOOGLE OAUTH (Opsional - Login tetap berfungsi tanpa ini)
# ============================
# Dapatkan di: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5174/auth/google/callback
FRONTEND_URL=http://localhost:5174

# ============================
# FRONTEND
# ============================
VITE_API_URL=http://localhost:3002/api
